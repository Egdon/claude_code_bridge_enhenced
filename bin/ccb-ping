#!/usr/bin/env python3
"""
ccb-ping - Test connectivity with AI providers.

Usage:
    ccb-ping [target] [--provider PROVIDER] [--session-file FILE] [--autostart]

Scopes:
    ccb-ping codex@2
    ccb-ping --provider codex
    ccb-ping
    ccb-ping codex            # legacy bare-provider compatibility
"""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

script_dir = Path(__file__).resolve().parent
lib_dir = script_dir.parent / "lib"
sys.path.insert(0, str(lib_dir))

from compat import setup_windows_encoding
import target_command_utils as target_cmd_utils

setup_windows_encoding()


PROVIDER_COMMS = {
    "gemini": ("gemini_comm", "GeminiCommunicator"),
    "codex": ("codex_comm", "CodexCommunicator"),
    "opencode": ("opencode_comm", "OpenCodeCommunicator"),
    "droid": ("droid_comm", "DroidCommunicator"),
    "claude": ("claude_comm", "ClaudeCommunicator"),
    "cursor": None,
}


def _usage() -> None:
    print("Usage: ccb-ping [target] [--provider PROVIDER] [--session-file FILE] [--autostart]", file=sys.stderr)
    print("", file=sys.stderr)
    print("Scopes:", file=sys.stderr)
    print("  ccb-ping codex@2", file=sys.stderr)
    print("  ccb-ping --provider codex", file=sys.stderr)
    print("  ccb-ping", file=sys.stderr)
    print("  ccb-ping codex            # legacy bare-provider compatibility", file=sys.stderr)
    print("", file=sys.stderr)
    print("Providers:", file=sys.stderr)
    print("  gemini, codex, opencode, droid, claude, cursor", file=sys.stderr)


def _resolve_work_dir(session_file: str | None) -> Path:
    if not session_file:
        return Path.cwd()
    raw = str(session_file).strip()
    if not raw:
        return Path.cwd()
    try:
        p = Path(os.path.expanduser(raw)).resolve()
    except Exception:
        p = Path(os.path.expanduser(raw)).absolute()
    parent_name = p.parent.name
    if parent_name in (".ccb", ".ccb_config"):
        return p.parent.parent
    return p.parent


def _resolve_scope_targets(work_dir: Path, target: str | None = None, provider: str | None = None) -> list[str]:
    positional = [target] if target else []
    targets, _scope = target_cmd_utils.resolve_scope_targets_for_command(work_dir, positional=positional, provider=provider)
    return targets


def _ping_targets(targets: list[str], work_dir: Path, autostart: bool = False) -> tuple[list[tuple[str, bool, str]], list[tuple[str, str]]]:
    results: list[tuple[str, bool, str]] = []
    errors: list[tuple[str, str]] = []
    for target in targets:
        healthy, message = target_cmd_utils.ping_target(work_dir, target)
        results.append((target, healthy, message))
        if not healthy:
            errors.append((target, message))
    return results, errors


def _run_legacy_provider_ping(provider: str, session_file: str | None = None, autostart: bool = False) -> int:
    provider_name = str(provider or "").strip().lower()
    if provider_name not in PROVIDER_COMMS:
        print(f"[ERROR] Unknown provider: {provider_name}", file=sys.stderr)
        print(f"[ERROR] Available: {', '.join(PROVIDER_COMMS.keys())}", file=sys.stderr)
        return 1

    if session_file:
        os.environ["CCB_SESSION_FILE"] = str(session_file)
    work_dir = _resolve_work_dir(session_file)

    if provider_name == "cursor":
        try:
            from uaskd_session import load_project_session
            from terminal import get_backend_for_session

            session = load_project_session(work_dir)
            if not session:
                print("[FAIL] No active Cursor CLI session found.")
                return 1
            pane_id = session.pane_id
            if not pane_id:
                print("[FAIL] No pane_id in .cursor-session")
                return 1
            backend = get_backend_for_session(session.data)
            if not backend:
                print("[FAIL] Terminal backend not available")
                return 1
            if backend.is_alive(pane_id):
                print(f"[OK] Cursor CLI pane {pane_id} is alive")
                return 0
            print(f"[FAIL] Cursor CLI pane {pane_id} is not alive")
            return 1
        except Exception as exc:
            print(f"[ERROR] Cursor CLI connectivity test failed: {exc}", file=sys.stderr)
            return 1

    module_name, class_name = PROVIDER_COMMS[provider_name]
    try:
        module = __import__(module_name)
        comm_class = getattr(module, class_name)

        if autostart:
            try:
                from askd_client import maybe_start_daemon, wait_for_daemon_ready
                from providers import (
                    CASK_CLIENT_SPEC,
                    DASK_CLIENT_SPEC,
                    GASK_CLIENT_SPEC,
                    LASK_CLIENT_SPEC,
                    OASK_CLIENT_SPEC,
                )

                specs = {
                    "codex": CASK_CLIENT_SPEC,
                    "gemini": GASK_CLIENT_SPEC,
                    "opencode": OASK_CLIENT_SPEC,
                    "claude": LASK_CLIENT_SPEC,
                    "droid": DASK_CLIENT_SPEC,
                }

                spec = specs.get(provider_name)
                if spec:
                    maybe_start_daemon(spec, work_dir)
                    wait_for_daemon_ready(spec, 0.5)
            except Exception as exc:
                print(f"[WARN] Autostart pre-check failed: {exc}", file=sys.stderr)

        comm = comm_class()
        healthy, message = comm.ping(display=False)
        print(message)
        return 0 if healthy else 1
    except ImportError as exc:
        print(f"[ERROR] Module import failed: {exc}", file=sys.stderr)
        return 1
    except Exception as exc:
        print(f"[ERROR] {provider_name.capitalize()} connectivity test failed: {exc}", file=sys.stderr)
        return 1


def _print_target_ping_result(target: str, healthy: bool, detail: str) -> None:
    message = str(detail or "").strip()
    if message and target in message:
        print(message)
        return
    prefix = "[OK]" if healthy else "[FAIL]"
    suffix = f" {message}" if message else ""
    print(f"{prefix} {target}{suffix}")


def main(argv: list[str] | None = None) -> int:
    argsv = list(sys.argv if argv is None else argv)
    parser = argparse.ArgumentParser(prog="ccb-ping", add_help=False)
    parser.add_argument("scope", nargs="?")
    parser.add_argument("--provider", dest="provider", default=None)
    parser.add_argument("--session-file", dest="session_file", default=None)
    parser.add_argument("--autostart", action="store_true", help="Start daemon if needed")
    parser.add_argument("-h", "--help", action="store_true")
    args, _unknown = parser.parse_known_args(argsv[1:])

    if args.help:
        _usage()
        return 0

    scope = str(args.scope or "").strip().lower()
    provider = str(args.provider or "").strip().lower() or None

    if provider and provider not in PROVIDER_COMMS:
        print(f"[ERROR] Unknown provider: {provider}", file=sys.stderr)
        print(f"[ERROR] Available: {', '.join(PROVIDER_COMMS.keys())}", file=sys.stderr)
        return 1

    if scope and "@" not in scope and not provider:
        return _run_legacy_provider_ping(scope, session_file=args.session_file, autostart=args.autostart)

    if scope and provider:
        print("[ERROR] target and --provider cannot be used together", file=sys.stderr)
        return 1

    work_dir = _resolve_work_dir(args.session_file)
    target = scope if "@" in scope else None
    targets = _resolve_scope_targets(work_dir, target=target, provider=provider)
    if not targets:
        print("[FAIL] No active targets found.", file=sys.stderr)
        return 1

    results, errors = _ping_targets(targets, work_dir, autostart=args.autostart)
    for target_name, healthy, detail in results:
        _print_target_ping_result(target_name, healthy, detail)
    return 0 if not errors else 1


if __name__ == "__main__":
    sys.exit(main())
