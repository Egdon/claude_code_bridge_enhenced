            status = get_mail_status()
            print("Mail Service Status")
            print("=" * 40)
            print(f"  Configured: {'Yes' if status['configured'] else 'No'}")
            print(f"  Enabled:    {'Yes' if status['enabled'] else 'No'}")
            print(f"  Email:      {status.get('email') or '-'}")
            print(f"  Provider:   {status.get('provider') or '-'}")
            daemon = status.get('daemon', {})
            if daemon.get('running'):
                print(f"  Daemon:     Running (PID: {daemon.get('pid')})")
            else:
                print("  Daemon:     Stopped")
            return 0
        except ImportError as e:
            print(f"Error: {e}", file=sys.stderr)
            return 1

    if args.subcommand == "test":
        try:
            from maild_client import test_mail_connection
            result = test_mail_connection()
            print("Mail Connection Test")
            print("=" * 40)
            imap = result.get('imap', {})
            smtp = result.get('smtp', {})
            print(f"  IMAP: {'✓' if imap.get('success') else '✗'} {imap.get('message', '')}")
            print(f"  SMTP: {'✓' if smtp.get('success') else '✗'} {smtp.get('message', '')}")
            return 0 if result.get('success') else 1
        except ImportError as e:
            print(f"Error: {e}", file=sys.stderr)
            return 1

    if args.subcommand == "config":
        try:
            from mail.config import load_config
            config = load_config()
            print("Mail Configuration")
            print("=" * 40)
            print(f"  Enabled:          {config.enabled}")
            print(f"  Provider:         {config.account.provider}")
            print(f"  Email:            {config.account.email or '-'}")
            print(f"  IMAP Host:        {config.account.imap.host}:{config.account.imap.port}")
            print(f"  SMTP Host:        {config.account.smtp.host}:{config.account.smtp.port}")
            print(f"  Routing Mode:     {config.routing.mode}")
            print(f"  Default Provider: {config.routing.default_provider}")
            print(f"  Poll Interval:    {config.polling.interval_seconds}s")
            # New fields
            allowed = config.routing.allowed_senders
            print(f"  Allowed Senders:  {', '.join(allowed) if allowed else '(all)'}")
            print(f"  Reply To:         {config.routing.reply_to_address or '(original sender)'}")
            return 0
        except ImportError as e:
            print(f"Error: {e}", file=sys.stderr)
            return 1

    parser.print_help()
    return 1


def cmd_droid_subcommand(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="ccb droid", description="Droid-specific commands")
    subparsers = parser.add_subparsers(dest="subcommand", help="Droid subcommands")

    setup_parser = subparsers.add_parser("setup-delegation", help="Register MCP delegation tools for Droid")
    setup_parser.add_argument("--force", action="store_true", help="Re-register MCP server")

    subparsers.add_parser("test-delegation", help="Verify MCP delegation tools are available")

    args = parser.parse_args(argv)
    if args.subcommand == "setup-delegation":
        return cmd_droid_setup_delegation(args)
    if args.subcommand == "test-delegation":
        return cmd_droid_test_delegation(args)
    parser.print_help()
    return 1


def main():
    argv = sys.argv[1:]
    if "--print-version" in argv:
        print(f"v{VERSION}")
        return 0

    if argv and argv[0] in {"-v", "--version"}:
        argv = ["version"]

    if argv and argv[0] == "up":
        print("❌ `ccb up` is no longer supported.", file=sys.stderr)
        print("💡 Use: ccb [targets...]  (or configure ccb.config)", file=sys.stderr)
        return 2

    if argv and argv[0] == "droid" and len(argv) > 1 and argv[1] in {"setup-delegation", "test-delegation"}:
        return cmd_droid_subcommand(argv[1:])

    if argv and argv[0] in {"kill", "ps", "add", "rm", "update", "version", "uninstall", "reinstall"}:
        parser = argparse.ArgumentParser(description="Claude AI unified launcher", add_help=True)
        subparsers = parser.add_subparsers(dest="command", help="Subcommands")

        kill_parser = subparsers.add_parser("kill", help="Terminate targets or clean up zombies")
        kill_parser.add_argument("targets", nargs="*", default=[], help="Targets to terminate (example: codex@1 claude@main)")
        kill_parser.add_argument("--provider", default=None, help="Terminate all active targets for one provider")
        kill_parser.add_argument("-f", "--force", action="store_true", help="Clean up all zombie tmux sessions globally")
        kill_parser.add_argument("-y", "--yes", action="store_true", help="Skip confirmation prompt (with -f)")

        subparsers.add_parser("ps", help="Show active targets in target-scoped view")

        add_parser = subparsers.add_parser("add", help="Start one target instance in the current project")
        add_parser.add_argument("target", help="Target to start (example: codex@2)")

        rm_parser = subparsers.add_parser("rm", help="Terminate one target instance in the current project")
        rm_parser.add_argument("target", help="Target to remove (example: codex@2)")

        update_parser = subparsers.add_parser("update", help="Update to latest or specified version")
        update_parser.add_argument("target", nargs="?",
                                   help="version like '4', '4.1', '4.1.3'")

        subparsers.add_parser("version", help="Show version and check for updates")
        subparsers.add_parser("uninstall", help="Uninstall ccb and clean configs")
        subparsers.add_parser("reinstall", help="Reinstall ccb and refresh configs")

        args = parser.parse_args(argv)
        if args.command == "kill":
            return cmd_kill(args)
        if args.command == "ps":
            return cmd_ps(args)
        if args.command == "add":
            return cmd_add(args)
        if args.command == "rm":
            return cmd_rm(args)
        if args.command == "update":
            return cmd_update(args)
        if args.command == "version":
            return cmd_version(args)
        if args.command == "uninstall":
            return cmd_uninstall(args)
        if args.command == "reinstall":
            return cmd_reinstall(args)
        parser.print_help()
        return 1

    # Handle 'ccb mail' subcommand
    if argv and argv[0] == "mail":
        return cmd_mail(argv[1:])

    start_parser = argparse.ArgumentParser(
        description="Claude AI unified launcher",
        add_help=True,
        epilog="Other commands: ccb ps | ccb add <target> | ccb rm <target> | ccb update | ccb version | ccb kill | ccb uninstall | ccb reinstall | ccb droid setup-delegation | ccb mail setup",
    )
    start_parser.add_argument(
        "providers",
        nargs="*",
        help="Targets to start (space or comma separated): codex@1 codex@2 claude@main (add cmd for a shell pane)",
    )
    start_parser.add_argument("-r", "--resume", "--restore", action="store_true", help="Resume context")
    start_parser.add_argument("-a", "--auto", action="store_true", help="Full auto permission mode")
    args = start_parser.parse_args(argv)
    return cmd_start(args)


if __name__ == "__main__":
    sys.exit(main())
