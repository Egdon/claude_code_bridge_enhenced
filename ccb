def _providers_requiring_shutdown_after_target_kill(project_id: str, killed_targets: list[str]) -> list[str]:
    _ = project_id
    providers: list[str] = []
    seen: set[str] = set()
    for target in killed_targets:
        provider = provider_of(target)
        if provider in seen:
            continue
        seen.add(provider)
        providers.append(provider)
    return providers



def _validate_single_target_arg(raw_target: str | None, *, command: str) -> tuple[int | None, str | None]:
    token = str(raw_target or "").strip()
    if not token:
        print(f"❌ missing target for `ccb {command}`", file=sys.stderr)
        return 2, None
    if "@" not in token:
        print(f"❌ bare provider is not accepted here: {token}", file=sys.stderr)
        print(f"💡 expected target in `provider@instance` format", file=sys.stderr)
        print(f"💡 use `ccb {command} {token}@main`", file=sys.stderr)
        return 2, None
    try:
        return None, validate_target(token)
    except ValueError:
        print(f"❌ invalid target: {token}", file=sys.stderr)
        return 2, None



def _load_registry_record_for_target(project_id: str, target: str) -> dict | None:
    canonical_target = validate_target(target)
    best: dict | None = None
    best_ts = -1

    for path in _iter_registry_files():
        record = _load_registry_file(path)
        if not isinstance(record, dict):
            continue
        updated_at = _coerce_updated_at(record.get("updated_at"), path)
        if _is_stale(updated_at):
            continue

        effective_project_id = str(record.get("ccb_project_id") or "").strip()
        if not effective_project_id:
            work_dir = str(record.get("work_dir") or "").strip()
            if work_dir:
                try:
                    effective_project_id = compute_ccb_project_id(Path(work_dir))
                except Exception:
                    effective_project_id = ""
        if effective_project_id != project_id:
            continue

        if canonical_target not in get_instances_map(record):
            continue

        if updated_at > best_ts:
            best = record
            best_ts = updated_at

    return best



def _mark_registry_target_inactive(project_id: str, target: str, *, ended_at: str | None = None) -> bool:
    record = _load_registry_record_for_target(project_id, target)
    if not isinstance(record, dict):
        return False

    session_id = str(record.get("ccb_session_id") or "").strip()
    if not session_id:
        return False

    canonical_target = validate_target(target)
    scoped_entry: dict[str, object] = {"active": False}
    if ended_at:
        scoped_entry["ended_at"] = ended_at

    update_record = {
        "ccb_session_id": session_id,
        "ccb_project_id": str(record.get("ccb_project_id") or project_id),
        "work_dir": str(record.get("work_dir") or Path.cwd()),
        "terminal": record.get("terminal"),
        "instances": {
            canonical_target: scoped_entry,
        },
    }
    return upsert_registry(update_record)



def _infer_runtime_root_from_target_payload(target: str, payload: dict) -> Path | None:
    runtime_value = str(payload.get("runtime_dir") or "").strip()
    if not runtime_value:
        return None

    runtime_path = Path(runtime_value)
    probe = runtime_path
    while probe.name and probe.name != "instances":
        probe = probe.parent
    if probe.name == "instances":
        return probe.parent

    provider_name = provider_of(target)
    if runtime_path.name == provider_name:
        return runtime_path.parent
    return runtime_path



def _load_active_target_context(work_dir: Path) -> dict[str, object] | None:
    control_context = load_control_plane_context(work_dir)

    sessions = list_target_sessions(work_dir)
    active_items: list[tuple[str, dict]] = []
    for target, payload in sessions.items():
        if not isinstance(payload, dict):
            continue
        if payload.get("active", True) is False:
            continue
        active_items.append((validate_target(target), payload))

    if not active_items:
        return control_context

    active_items.sort(key=lambda item: _ps_target_sort_key(item[0]))
    parent_target, parent_payload = active_items[0]
    parent_pane = str(parent_payload.get("pane_id") or parent_payload.get("tmux_session") or "").strip() or None
    session_id = str(parent_payload.get("session_id") or parent_payload.get("ccb_session_id") or "").strip()
    runtime_root = _infer_runtime_root_from_target_payload(parent_target, parent_payload)
    terminal = str(parent_payload.get("terminal") or "").strip() or None

    if not parent_pane and control_context:
        parent_pane = str(control_context.get("parent_pane") or "").strip() or None
    if not terminal and control_context:
        terminal = str(control_context.get("terminal") or "").strip() or None

    if (not session_id or runtime_root is None) and control_context:
        return control_context
    if not session_id or runtime_root is None:
        return None

    return {
        "session_id": session_id,
        "runtime_root": runtime_root,
        "parent_pane": parent_pane,
        "terminal": terminal,
    }



def cmd_add(args):
    err, canonical_target = _validate_single_target_arg(getattr(args, "target", None), command="add")
    if err is not None:
        return err
    assert canonical_target is not None

    work_dir = Path.cwd()
    try:
        healthy, _message = target_cmd_utils.ping_target(work_dir, canonical_target)
    except Exception:
        healthy = False
    if healthy:
        print(f"ℹ️  {canonical_target} is already active")
        return 0

    live_response = request_control_plane_operation(work_dir, op="add", target=canonical_target)
    if isinstance(live_response, dict):
        message = str(live_response.get("message") or live_response.get("reply") or "").strip()
        if message:
            print(message)
        return int(live_response.get("exit_code") or 0)

    context = _load_active_target_context(work_dir)
    if not context:
        print("❌ No active CCB target context found for this project.", file=sys.stderr)
        print("💡 Start at least one target with `ccb <target...>` before using `ccb add`.", file=sys.stderr)
        return 2

    launcher = AILauncher(targets=[canonical_target])
    launcher.session_id = str(context["session_id"])
    launcher.runtime_dir = Path(context["runtime_root"])
    launcher.runtime_dir.mkdir(parents=True, exist_ok=True)
    launcher.project_root = work_dir
    launcher.project_id = compute_ccb_project_id(work_dir)
    if context.get("terminal"):
        launcher.terminal_type = str(context["terminal"])

    pane_id = launcher._start_target(
        canonical_target,
        parent_pane=str(context.get("parent_pane") or "").strip() or None,
        direction="bottom",
    )
    if not pane_id:
        print(f"❌ failed to add {canonical_target}", file=sys.stderr)
        return 1

    print(f"✅ added {canonical_target}")
    return 0



def cmd_rm(args):
    err, canonical_target = _validate_single_target_arg(getattr(args, "target", None), command="rm")
    if err is not None:
        return err
